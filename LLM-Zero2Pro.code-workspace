{
  "folders": [
    {
      "name": "LLM-Zero2Pro 学习空间",
      "path": "learning"
    }
  ],
  "settings": {
    "python.defaultInterpreterPath": "${workspaceFolder}/../.venv",
    "python.terminal.activateEnvironment": true,
    "jupyter.notebookFileRoot": "${workspaceFolder}",
    "files.exclude": {
      "**/.ipynb_checkpoints": true,
      "**/__pycache__": true,
      ".pytest_cache": true,
      ".ruff_cache": true,
      ".venv": true
    },
    "terminal.integrated.cwd": "${workspaceFolder}"
  },
  "extensions": {
    "recommendations": [
      "ms-python.python",
      "ms-toolsai.jupyter",
      "yzhang.markdown-all-in-one",
      "ms-vscode.live-server"
    ]
  },
  "tasks": {
    "version": "2.0.0",
    "tasks": [
      {
        "label": "课程：环境诊断",
        "type": "shell",
        "command": "uv run llm-course doctor",
        "problemMatcher": [],
        "options": {
          "cwd": "${workspaceFolder}/.."
        }
      },
      {
        "label": "课程：检查 48 课资产",
        "type": "shell",
        "command": "uv run llm-course course check --no-tests",
        "problemMatcher": [],
        "options": {
          "cwd": "${workspaceFolder}/.."
        }
      },
      {
        "label": "课程：核查当前 starter",
        "type": "shell",
        "command": "uv run llm-course exercises check ${input:exerciseId}",
        "problemMatcher": [],
        "options": {
          "cwd": "${workspaceFolder}/.."
        }
      },
      {
        "label": "课程：核查贯穿式大作业",
        "type": "shell",
        "command": "uv run llm-course projects check ${input:projectId}",
        "problemMatcher": [],
        "options": {
          "cwd": "${workspaceFolder}/.."
        }
      },
      {
        "label": "课程：检查双格式实验同步",
        "type": "shell",
        "command": "uv run python scripts/sync_labs.py --check",
        "problemMatcher": [],
        "options": {
          "cwd": "${workspaceFolder}/.."
        }
      }
    ],
    "inputs": [
      {
        "id": "exerciseId",
        "type": "promptString",
        "description": "输入练习编号或别名，例如 07 或 rope",
        "default": "01"
      },
      {
        "id": "projectId",
        "type": "promptString",
        "description": "输入大作业编号或别名，例如 01 或 end-to-end-lm",
        "default": "01"
      }
    ]
  }
}
